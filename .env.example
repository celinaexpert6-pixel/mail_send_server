# Server port (default 3000)
PORT=3000

# PostgreSQL (optional – omit for email-only mode; claims are still sent to CLAIM_FORM_EMAIL)
# Example: postgresql://user:password@localhost:5432/claimform
# DATABASE_URL=postgresql://localhost:5432/claimform

# Allowed origin for CORS (your Shopify store URL, e.g. https://your-store.myshopify.com)
# Use * for development only
CLAIM_FORM_ORIGIN=https://your-store.myshopify.com

# Resend – email each claim to these addresses (comma-separated for multiple)
# Get an API key at https://resend.com (free tier: 100 emails/day, 3,000/month)
RESEND_API_KEY=
CLAIM_FORM_EMAIL=info@tbint.de,austin.rider0202@gmail.com,karina.tuduce@ecommerce-today.com

# Optional: "From" address (use onboarding@resend.dev for testing; verify your domain for production)
# RESEND_FROM_EMAIL=onboarding@resend.dev
# RESEND_FROM_NAME=Claim Form
