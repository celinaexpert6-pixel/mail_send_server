# Server port (default 3000)
PORT=3000

# PostgreSQL connection string
# Must include USER and PASSWORD: postgresql://USER:PASSWORD@HOST:5432/DATABASE
# Use 127.0.0.1 instead of localhost on Windows. Replace postgres and YOUR_PASSWORD with your PostgreSQL login.
# Example: postgresql://postgres:yourpassword@127.0.0.1:5432/claimform
DATABASE_URL=postgresql://postgres:123456@127.0.0.1:5432/claimform

# Allowed origin for CORS (your Shopify store URL)
# Use * for development only
CLAIM_FORM_ORIGIN=*

